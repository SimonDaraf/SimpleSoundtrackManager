<settingswindow:SettingsApplicationWindow xmlns:settingswindow="clr-namespace:SimpleSoundtrackManager.MVVM.View.CustomWindows.SettingsWindow"
        x:Class="SimpleSoundtrackManager.MVVM.View.Components.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleSoundtrackManager.MVVM.View.Components"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d"
        Style="{StaticResource ApplicationSettingsWindow}"
        Title="Pick Color" Height="240" Width="200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <skia:SKElement x:Name="ColorCanvas"
                        Margin="10, 10, 10, 0"
                        PaintSurface="ColorCanvas_PaintSurface"
                        MouseDown="ColorCanvas_MouseDown"
                        MouseMove="ColorCanvas_MouseMove"
                        MouseUp="ColorCanvas_MouseUp"
                        Cursor="Cross"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Row="1" Style="{StaticResource ButtonStyle}"
                    Content="OK"
                    Width="50"
                    Click="OK_Click" HorizontalAlignment="Left" Margin="10, 15"/>

            <Border x:Name="PreviewBorder" Grid.Column="2" Width="30" Height="30" Margin="10, 0"></Border>
        </Grid>
        
    </Grid>
</settingswindow:SettingsApplicationWindow>
