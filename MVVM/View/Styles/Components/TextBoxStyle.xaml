<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="TextBox" x:Key="TextBoxStyle">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border BorderBrush="{StaticResource DropdownBorder}" BorderThickness="1" Margin="{TemplateBinding Margin}">
                        <TextBox Background="Transparent" BorderThickness="0" IsReadOnly="{TemplateBinding IsReadOnly}"
                                 Text="{TemplateBinding Text}" Foreground="{StaticResource Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>