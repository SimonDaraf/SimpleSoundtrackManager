<UserControl x:Class="SimpleSoundtrackManager.MVVM.View.TrackSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimpleSoundtrackManager.MVVM.View"
             mc:Ignorable="d" d:DesignWidth="800">
    <Border BorderBrush="{Binding BrushColor}" BorderThickness="0, 0, 0, 1" Margin="0, 0, 0, 5" Background="{Binding TrackGradientBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Name:" Foreground="{StaticResource Foreground}" Margin="10, 0" VerticalAlignment="Center" FontSize="16"/>
                        <TextBox Grid.Column="0" Text="{Binding Track.Name}" VerticalAlignment="Center" FontSize="14" Margin="10, 0" Foreground="{StaticResource Foreground}"
                                 Style="{StaticResource TextBoxStyle}" Width="400"/>
                        <Button Grid.Column="1" Style="{StaticResource ButtonStyle}" BorderBrush="{Binding BrushColor}"
                                Command="{Binding OpenColorPickerCommand}" Margin="5, 10" Content="Color" Padding="5,0"/>
                    </StackPanel>
                </Grid>
                
                <Menu Grid.Column="2" Height="20" Background="Transparent" VerticalAlignment="Center" Margin="10, 0">
                    <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownStyle}" Header="Edit">
                        <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownItemStyle}"
                                  Header="Browse" Height="20" VerticalAlignment="Top" Command="{Binding BrowseCommand}"/>
                        <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownItemStyle}"
                                  Header="Delete" Height="20" VerticalAlignment="Top"
                                  Command="{Binding DeleteCommand}"/>
                    </MenuItem>
                </Menu>
            </Grid>

            <Grid Grid.Row="1" Height="200">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Style="{StaticResource ButtonStyle}" BorderBrush="{Binding BrushColor}"
                            Command="{Binding TogglePlaybackCommand}" Margin="10, 10" Content="{Binding PlaybackState}" Padding="10,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
