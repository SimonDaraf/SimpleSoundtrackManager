<UserControl x:Class="SimpleSoundtrackManager.MVVM.View.TrackSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimpleSoundtrackManager.MVVM.View"
             xmlns:components="clr-namespace:SimpleSoundtrackManager.MVVM.View.Components"
             mc:Ignorable="d" 
             xmlns:vm="clr-namespace:SimpleSoundtrackManager.MVVM.ViewModel"
             d:DataContext="{d:DesignInstance Type=vm:TrackSelectorViewModel}"     
             d:DesignWidth="800">
    <Border BorderBrush="{Binding BrushColor}" BorderThickness="0, 0, 0, 1" Margin="0, 0, 0, 5" Background="{Binding TrackGradientBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="NameInput" Grid.Column="0" Text="{Binding Track.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" FontSize="14" Margin="0, 0, 10, 0" Foreground="{StaticResource Foreground}"
                                 Style="{StaticResource TextBoxStyle}" Width="300"/>
                        <Button Grid.Column="1" Style="{StaticResource ButtonStyle}" BorderBrush="{Binding BrushColor}"
                                Command="{Binding OpenColorPickerCommand}" Margin="5, 10" Content="Color" Padding="5,0"/>

                        <TextBlock Text="Category:" Margin="10, 0, 10, 0" Foreground="{StaticResource Foreground}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CategoryInput" Grid.Column="0" Text="{Binding Track.Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" FontSize="14" Margin="0, 0, 10, 0" Foreground="{StaticResource Foreground}"
                                 Style="{StaticResource TextBoxStyle}" Width="200"/>
                    </StackPanel>
                </Grid>
                
                <Menu Grid.Column="2" Height="20" Background="Transparent" VerticalAlignment="Center" Margin="10, 0">
                    <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownStyle}" Header="Edit">
                        <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownItemStyle}"
                                  Header="Change Audio File" Height="25" VerticalAlignment="Top" Command="{Binding BrowseCommand}"/>
                        <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownItemStyle}"
                                  Header="Delete" Height="25" VerticalAlignment="Top"
                                  Command="{Binding DeleteCommand}"/>
                    </MenuItem>
                </Menu>
            </Grid>

            <Grid Grid.Row="1" Height="200">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <components:TrackPlayer Track="{Binding Track}" WaveformColor="{Binding TrackColor}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsPlaying="{Binding IsSource}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Style="{StaticResource ButtonStyle}" BorderBrush="{Binding BrushColor}"
                            Command="{Binding TogglePlaybackCommand}" Margin="10, 10" Content="{Binding PlaybackState}" Padding="10,0"/>
                    <TextBlock Text="Start: " Foreground="{StaticResource Foreground}" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox Style="{StaticResource TextBoxStyle}" Margin="5, 10" Text="{Binding Track.StartMsPoint}" Width="Auto"
                             IsReadOnly="True" Foreground="{StaticResource Foreground}"/>

                    <TextBlock Margin="10, 0, 0, 0" Text="Loop: " Foreground="{StaticResource Foreground}" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox Style="{StaticResource TextBoxStyle}" Margin="5, 10" Text="{Binding Track.LoopMsPoint}" Width="Auto"
                             IsReadOnly="True" Foreground="{StaticResource Foreground}"/>

                    <TextBlock Margin="10, 0, 0, 0" Text="Transition Length: " Foreground="{StaticResource Foreground}" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox Style="{StaticResource TextBoxStyle}" Margin="5, 10" Text="{Binding Track.TransitionLengthTime}" Width="Auto"
                            IsReadOnly="True" Foreground="{StaticResource Foreground}"/>

                    <TextBlock Margin="10, 0, 0, 0" Text="Volume: " Foreground="{StaticResource Foreground}" FontSize="14" VerticalAlignment="Center"/>
                    <Slider Minimum="0" Maximum="1" Value="{Binding Track.TrackVolume}" 
                            Width="150" Style="{StaticResource VolumeSliderStyle}" Margin="10"
                            SmallChange="0.01" LargeChange="0.1" TickFrequency="0.01" TickPlacement="None"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
