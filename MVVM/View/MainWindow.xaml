<appwindow:MainApplicationWindow  xmlns:appwindow="clr-namespace:SimpleSoundtrackManager.MVVM.View.CustomWindows.AppWindow"
                                  x:Class="SimpleSoundtrackManager.MVVM.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleSoundtrackManager"
        mc:Ignorable="d"
        xmlns:vm="clr-namespace:SimpleSoundtrackManager.MVVM.ViewModel"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}" 
        Style="{StaticResource ApplicationWindow}"
        Title="{Binding Title}" >
    <Grid>
        <ContentPresenter Content="{Binding ActiveViewModel}"/>
    </Grid>
</appwindow:MainApplicationWindow>
