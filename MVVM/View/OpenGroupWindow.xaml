<settingswindow:SettingsApplicationWindow  
      xmlns:settingswindow="clr-namespace:AutomatedSoundtrackSystem.MVVM.View.CustomWindows.SettingsWindow"
      x:Class="AutomatedSoundtrackSystem.MVVM.View.OpenGroupWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AutomatedSoundtrackSystem.MVVM.View"
      mc:Ignorable="d"
      Style="{StaticResource ApplicationSettingsWindow}"
      Height="720"
      Width="460"
      Title="Welcome">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="10, 0">
            <Menu Background="Transparent" Height="20" VerticalAlignment="Center">
                <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownItemStyle}"
                          Header="New" VerticalAlignment="Top" Margin="0, 0, 10, 0"/>
                <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownItemStyle}"
                          Header="Browse" VerticalAlignment="Top" Command="{Binding BrowseGroupCommand}"/>
            </Menu>
        </StackPanel>
        <Border Grid.Row="1" BorderThickness="0, 1, 0, 0" BorderBrush="{StaticResource DropdownBorder}">
            
        </Border>
    </Grid>
</settingswindow:SettingsApplicationWindow>
