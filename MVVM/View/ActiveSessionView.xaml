<UserControl x:Class="SimpleSoundtrackManager.MVVM.View.ActiveSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SimpleSoundtrackManager.MVVM.View"
             xmlns:vm="clr-namespace:SimpleSoundtrackManager.MVVM.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:DataContext="{d:DesignInstance Type=vm:ActiveSessionViewModel}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Border BorderThickness="0, 0, 0, 1" BorderBrush="{StaticResource DropdownBorder}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="5">
                <TextBlock Text="Filter:" Foreground="{StaticResource Foreground}" Margin="0, 0, 10, 0" VerticalAlignment="Center"/>
                <ComboBox Style="{StaticResource DropdownStyle}" VerticalAlignment="Bottom"
                ItemsSource="{Binding Filters}" SelectedValue="{Binding ActiveFilter}" MinWidth="100" Margin="0, 0, 20, 0"/>
                <TextBlock Text="Show Active:" Foreground="{StaticResource Foreground}" Margin="0, 0, 10, 0" VerticalAlignment="Center"/>
                <CheckBox VerticalAlignment="Center" IsChecked="{Binding ShowActive}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="10, 10, 10, 0" VerticalAlignment="Top">
                <ItemsControl x:Name="ItemsControl"
                              ItemsSource="{Binding TrackViews}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        <Border Grid.Row="2" BorderBrush="{StaticResource DropdownBorder}"
                Padding="0, 10, 0, 0"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource ButtonStyle}" Content="End Session" Padding="10, 0" Height="25"
                            Command="{Binding EndSessionCommand}"/>
                    <TextBlock  Text="{Binding Status}" Foreground="{StaticResource Foreground}" VerticalAlignment="Center" Margin="10, 0"
                                HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Horizontal" Margin="10, 0">
                    <TextBlock Margin="0, 0, 10, 0" Text="Volume: " Foreground="{StaticResource Foreground}" FontSize="14" VerticalAlignment="Center"/>
                    <Slider Minimum="0" Maximum="1" Value="{Binding Volume}" 
                            Width="150" Style="{StaticResource VolumeSliderStyle}"
                            SmallChange="0.01" LargeChange="0.1" TickFrequency="0.01" TickPlacement="None"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
