<UserControl x:Class="AutomatedSoundtrackSystem.MVVM.View.TrackSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutomatedSoundtrackSystem.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <Border BorderBrush="{StaticResource DropdownBorder}" BorderThickness="0, 0, 0, 1" Height="100" Margin="0, 0, 0, 5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Track.Name}" VerticalAlignment="Center" FontSize="14" Margin="10, 0" Foreground="{StaticResource Foreground}"/>
                <Menu Grid.Column="2" Height="20" Background="Transparent" VerticalAlignment="Center" Margin="10, 0">
                    <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownStyle}" Header="Edit">
                        <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownItemStyle}"
                                  Header="Open" Height="20" VerticalAlignment="Top"/>
                        <MenuItem Style="{StaticResource ApplicationWindowToolbarDropdownItemStyle}"
                                  Header="Delete" Height="20" VerticalAlignment="Top"/>
                    </MenuItem>
                </Menu>
            </Grid>
        </Grid>
    </Border>
</UserControl>
